# RFObserver sensor configuration
# Copy to /etc/rfobserver/rfobserver.env and edit

# Receiver
RFOBS_FREQUENCY_START=915000000
RFOBS_FREQUENCY_END=915000000
RFOBS_BANDWIDTH=26000000
RFOBS_DURATION_SEC=1.0
RFOBS_GAIN=35

# Identity
RFOBS_HOSTNAME=sensor-01
RFOBS_ORGANIZATION=MyOrg
RFOBS_COORDINATES=40.0150N,105.2705W

# NATS
RFOBS_NATS_HOST=localhost
RFOBS_NATS_PORT=4222
# RFOBS_NATS_TOKEN=

# Storage
RFOBS_STORAGE_PATH=/var/lib/rfobserver
RFOBS_DB_PATH=/var/lib/rfobserver/rfobserver.db
RFOBS_ARCHIVE_MAX_GB=50.0

# WebUI
RFOBS_WEB_HOST=0.0.0.0
RFOBS_WEB_PORT=8080

# OpenZMS (optional)
# RFOBS_ZMS_ZMC_HTTP=http://zmc.example.com
# RFOBS_ZMS_IDENTITY_HTTP=http://identity.example.com
# RFOBS_ZMS_TOKEN=
# RFOBS_ZMS_MONITOR_ID=

# Logging
RFOBS_LOG_LEVEL=INFO

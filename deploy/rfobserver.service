[Unit]
Description=RFObserver Sensor Pipeline
# The sensor is a NATS client to a remote RFS broker, so no local
# nats-server.service ordering is needed.
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=rfobserver
Group=rfobserver
EnvironmentFile=/etc/rfobserver/rfobserver.env
ExecStart=/usr/local/bin/rfobserver run
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=rfobserver

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ReadWritePaths=/var/lib/rfobserver /tmp/rfobserver

[Install]
WantedBy=multi-user.target
